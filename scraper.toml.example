db_path = "book_metadata.db"
concurrency_limit = 5
# Minimum seconds between HTTP requests (None = no limit).  Set to 1.0 for
# publisher sites that require polite crawling.
# http_rate_limit = 1.0
log_file = "book-metadata-scraper.log"
log_level = "INFO"

enabled_scoped_sources = []
enabled_universal_sources = []

# Example: enable specific sources
# enabled_scoped_sources = ["aethon_books"]
# enabled_universal_sources = ["google_books"]

# Per-source configuration blocks
# [source_config.google_books]
# api_key = "YOUR_KEY_HERE"
